# ============================================================
# BRIGHT EDGE AGENCY — Environment Variables
# Copy to .env.local for development. NEVER commit .env.local.
# On Vercel, set these in Project Settings → Environment Variables.
# ============================================================

# -----------------------------
# Supabase (required)
# -----------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (do NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------
# Site
# -----------------------------
VITE_SITE_URL=https://brightedge.co.ke
VITE_SITE_NAME=Bright Edge Agency

# -----------------------------
# Phase 1: keep Supabase Storage
# Phase 6: migrate to Cloudflare R2
# -----------------------------
# Public bucket base URL (images served from here)
VITE_STORAGE_BASE_URL=

# R2 (Phase 6 — leave blank for now)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bright-edge-images
R2_PUBLIC_BASE_URL=

# -----------------------------
# Short links (Phase 0d)
# -----------------------------
# Short URL prefix used by /p/{nanoid} redirects.
# Defaults to VITE_SITE_URL when unset.
VITE_SHORT_URL_BASE=

# -----------------------------
# OTP providers (Phase 2)
# Free tier: Gmail SMTP (Supabase Auth email) + WhatsApp click-to-chat
# Paid later if needed: Twilio / Africa's Talking / Vonage
# -----------------------------
# WhatsApp Business number for OTP fallback (e.g. 254700000000)
VITE_WHATSAPP_OTP_NUMBER=

# Optional: SMTP relay for richer email templates
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# -----------------------------
# AI captions (Phase 4 — hybrid)
# Phase 0e ships template-based captions only (no key needed).
# Add OpenAI later for hybrid mode.
# -----------------------------
OPENAI_API_KEY=

# -----------------------------
# SaaS / Stripe (Phase 2 prep — DO NOT USE YET)
# -----------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
